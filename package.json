{
  "name": "roastplus",
  "version": "0.17.2",
  "private": true,
  "scripts": {
    "dev": "npm run generate:sound-list && next dev",
    "build": "npm run generate:sound-list && next build",
    "build:dev": "npm run generate:sound-list && env-cmd -f .env.development.local next build",
    "start": "next start",
    "deploy:prod": "firebase use default && npm run build && firebase deploy",
    "deploy:dev": "firebase use development && npm run build:dev && firebase deploy",
    "lint": "eslint",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "generate:sound-list": "tsx scripts/generate-sound-list.ts",
    "prepare": "husky",
    "security": "npm audit --audit-level=high",
    "complexity": "lizard ./app ./components ./hooks ./lib ./types ./scripts -C 15 -L 50 -w",
    "deadcode": "knip",
    "maintenance": "npm run complexity && npm run security && npm run deadcode && npm run skill:validate",
    "skill:validate": "tsx scripts/validate-ui-skill.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "remotion:studio": "npx remotion studio remotion/index.ts",
    "remotion:render": "npx remotion render remotion/index.ts RoastPlusIntro out/roastplus-intro.mp4"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "clsx": "^2.1.1",
    "firebase": "^12.10.0",
    "framer-motion": "^12.36.0",
    "lottie-react": "^2.4.1",
    "next": "^16.0.8",
    "next-themes": "^0.4.6",
    "phosphor-react": "^1.4.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "ts-fsrs": "^5.2.3",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs}": [
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@remotion/cli": "^4.0.435",
    "@remotion/google-fonts": "^4.0.435",
    "@remotion/transitions": "^4.0.435",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "env-cmd": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "^16.0.8",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "knip": "^5.86.0",
    "lint-staged": "^16.3.3",
    "remotion": "^4.0.434",
    "tailwindcss": "^4",
    "tsx": "^4.7.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
